class Solution {
public:
    int minSubArrayLen(int target, vector<int>& nums) {
        int low=0;
        int high=0;
        int sum=0;
        int res=INT_MAX;
        int ans=0;
        int n=nums.size();
      while(high<n){
        sum=sum+nums[high];
        while(sum>=target){
        res=min(res,ans);
            ans=high-low+1;
            sum=sum-nums[low];
            low++;
        }
        high++;
      }
    return ans;
    }
};
